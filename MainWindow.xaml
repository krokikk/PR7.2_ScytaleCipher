<Window x:Class="PR7._2_ScytaleCipher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR7._2_ScytaleCipher"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Шифр Сцитала"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Ввод -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">

            <TextBlock Text="Введите текст:"/>
            <TextBox x:Name="InputTextBox"
                     Height="60"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="0,5,0,10"/>

            <TextBlock Text="Диаметр цилиндра:"/>
            <TextBox x:Name="DiameterTextBox"
                     Height="25"
                     Margin="0,5,0,0"
                     ToolTip="Введите целое число больше 0"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button Content="Зашифровать"
                    Width="120"
                    Margin="5"
                    Click="Encrypt_Click"/>

            <Button Content="Расшифровать"
                    Width="120"
                    Margin="5"
                    Click="Decrypt_Click"/>

            <Button Content="Очистить"
                    Width="100"
                    Margin="5"
                    Click="Clear_Click"/>
        </StackPanel>

        <!-- Результат -->
        <StackPanel Grid.Row="3">

            <TextBlock Text="Результат:"/>
            <TextBox x:Name="ResultTextBox"
                     Height="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     Margin="0,5,0,10"/>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="Red"
                       FontWeight="Bold"/>
        </StackPanel>

    </Grid>

</Window>
